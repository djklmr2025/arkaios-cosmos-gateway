# Puerto del gateway
PORT=8787

# Token bearer requerido para /aida/gateway
AIDA_AUTH_TOKEN=replace_with_secure_token

# Upstream OpenAI-compatible (normalmente arkaios-service-proxy)
UPSTREAM_BASE_URL=https://arkaios-service-proxy.onrender.com
UPSTREAM_PATH=/v1/chat/completions
UPSTREAM_API_KEY=replace_with_proxy_api_key

# Modelo default para requests chat/completion
DEFAULT_MODEL=aida

# Mapa simple agent_id -> model (JSON string)
# Ejemplo: {"puter":"aida","arkaios":"arkaios","lab":"lab"}
AGENT_MODEL_MAP={"puter":"aida","arkaios":"arkaios","lab":"lab"}
